# NPM Configuration
# Automatically save exact versions (not ranges) to package-lock.json
save-exact = false

# Use package-lock.json
package-lock = true

# Don't run scripts automatically
ignore-scripts = false

# Use strict peer dependencies
legacy-peer-deps = false

# Prefer offline when possible
prefer-offline = false

# Progress bar
progress = true

# Log level
loglevel = warn

